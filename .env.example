# Campus Facility Booking System — Environment Variables
# Copy this file to .env and fill in production values.
# Never commit a .env file with real secrets.

# ── Django Core ────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=campus.example.com,www.campus.example.com

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Uncomment these in prod.py when ready to enable real email notifications.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@campus.example.com
# EMAIL_HOST_PASSWORD=your-smtp-password

# ── SSO / OAuth ────────────────────────────────────────────────────────────────
# Uncomment when adding django-allauth or social-auth-app-django.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
